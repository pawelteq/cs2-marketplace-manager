# Domyślna waluta porównania (np. PLN, EUR, USD)
NEXT_PUBLIC_DEFAULT_CURRENCY=PLN

# CSFloat zwraca ceny w centach USD. Aby porównywać w jednej walucie,
# podaj kurs przeliczenia USD -> waluta domyślna (1 USD = X waluty).
# Przykład dla PLN: 3.85 ; dla EUR: 0.92
USD_TO_DEFAULT_FX=3.85

# (Opcjonalnie) klucz API CSFloat — wymagany dopiero dla akcji (listowanie itp.),
# nie jest potrzebny do publicznego odczytu listingów.
CSFLOAT_API_KEY=
