# Waluta porównania (PLN, EUR, USD, ...). Cała aplikacja działa w tej walucie:
# Skinport pobierany jest natywnie w niej, CSFloat (USD) jest do niej przeliczany.
NEXT_PUBLIC_DEFAULT_CURRENCY=PLN

# Kurs USD -> waluta domyślna.
# ZOSTAW PUSTE, by kurs dobierał się automatycznie z tabeli w lib/config.ts
# (zgodnie z wybraną walutą). Ustaw wartość TYLKO jeśli chcesz nadpisać kurs ręcznie,
# np. USD_TO_DEFAULT_FX=3.80
USD_TO_DEFAULT_FX=

# (Opcjonalnie) klucz API CSFloat — wymagany dopiero dla akcji (listowanie itp.),
# nie jest potrzebny do publicznego odczytu listingów.
CSFLOAT_API_KEY=
