# Waluta porównania (PLN, EUR, USD, ...). Cała aplikacja działa w tej walucie:
# Skinport pobierany jest natywnie w niej, CSFloat (USD) jest do niej przeliczany.
NEXT_PUBLIC_DEFAULT_CURRENCY=PLN

# Kurs USD -> waluta domyślna.
# ZOSTAW PUSTE — kurs jest automatycznie pobierany z api.frankfurter.app (cache 1h)
# z fallbackiem na statyczną tabelę w lib/config.ts.
# Ustaw tylko jeśli chcesz zablokować stały kurs (np. testy, środowisko bez internetu).
USD_TO_DEFAULT_FX=

# (Opcjonalnie) klucz API CSFloat — wymagany dopiero dla akcji (listowanie itp.),
# nie jest potrzebny do publicznego odczytu listingów.
CSFLOAT_API_KEY=

# Prowizja sprzedawcy Skinport. Konto standardowe: 0.12 (12%). Subskrypcja Pro: 0.08 (8%).
# Domyślnie: 0.12
SKINPORT_SELLER_FEE=

# Prowizja sprzedawcy CSFloat. Standardowo: 0.02 (2%).
# Domyślnie: 0.02
CSFLOAT_SELLER_FEE=
